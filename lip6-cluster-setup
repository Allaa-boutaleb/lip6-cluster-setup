# parse_duration INPUT
# Accepts: 30m, 8h, 3d, 3d 12h, 1d 6h 30m, H:M:S, bare number (hours)
parse_duration() {
    local input
    input=$(printf '%s' "$*" | tr '[:upper:]' '[:lower:]')
    input=$(printf '%s' "$input" | xargs)
    [ -z "$input" ] && return 1

    if [[ "$input" =~ ^[0-9]+:[0-9]+:[0-9]+$ ]]; then
        local h m s
        IFS=':' read -r h m s <<< "$input"
        h=$((10#$h))
        m=$((10#$m))
        s=$((10#$s))
        printf "%d:%d:%d\n" "$h" "$m" "$s"
        return 0
    fi

    local total_minutes=0
    local matched=false
    if [[ "$input" =~ [dhm] ]]; then
        if [[ "$input" =~ ([0-9]+)d ]]; then
            total_minutes=$(( total_minutes + ${BASH_REMATCH[1]} * 1440 ))
            matched=true
        fi
        if [[ "$input" =~ ([0-9]+)h ]]; then
            total_minutes=$(( total_minutes + ${BASH_REMATCH[1]} * 60 ))
            matched=true
        fi
        if [[ "$input" =~ ([0-9]+)m ]]; then
            total_minutes=$(( total_minutes + ${BASH_REMATCH[1]} ))
            matched=true
        fi
        $matched || return 1
    elif [[ "$input" =~ ^[0-9]+$ ]]; then
        total_minutes=$(( input * 60 ))
    else
        return 1
    fi

    local hours=$(( total_minutes / 60 ))
    local mins=$(( total_minutes % 60 ))
    echo "${hours}:${mins}:0"
}

spinner_step() {
    local label="$1"
    printf "  ${DIM}%-2s %s...${NC}" ">" "$label"
}

spinner_done() {
    local text="$1"
    printf "\r\033[K  ${GREEN}ok${NC} %s\n" "$text"
}

spinner_warn() {
    local text="$1"
    printf "\r\033[K  ${YELLOW}--${NC} %s\n" "$text"
}

run_spinner() {
    local label="$1"
    shift
    local tmp="${TMPDIR:-/tmp}/lip6-spinner.$$.$RANDOM"
    local frames='|/-\'
    local i=0
    local pid rc

    "$@" > "${tmp}.out" 2> "${tmp}.err" &
    pid=$!
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r\033[K  ${CYAN}%s${NC} %s" "${frames:$((i % 4)):1}" "$label" >&2
        i=$((i + 1))
        sleep 0.12
    done
    wait "$pid"
    rc=$?
    printf "\r\033[K" >&2
    cat "${tmp}.out"
    if [ "$rc" -ne 0 ] && [ -s "${tmp}.err" ]; then
        cat "${tmp}.err" >&2
    fi
    rm -f "${tmp}.out" "${tmp}.err"
    return "$rc"
}

