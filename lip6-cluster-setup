collect_status() {
    local raw running pending tunnels
    raw=$(ssh -n -o BatchMode=yes -o ConnectTimeout=3 conv "printf 'front|reachable\n'; squeue -h -u ${CONV_USER} -o '%T|%R' 2>/dev/null" 2>/dev/null || true)
    if ! printf '%s\n' "$raw" | grep -q '^front|reachable$'; then
        printf "front|unreachable\n"
        printf "jobs|not available\n"
        printf "tunnels|%s\n" "$(find "$TUNNEL_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')"
        printf "gpu|use option 4\n"
        return
    fi

    printf "front|reachable\n"
    running=$(printf '%s\n' "$raw" | awk -F'|' '$1=="RUNNING"{c++} END{print c+0}')
    pending=$(printf '%s\n' "$raw" | awk -F'|' '$1!="RUNNING" && $1!="front" && $1!=""{c++} END{print c+0}')
    tunnels=$(find "$TUNNEL_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')
    printf "jobs|%s running / %s pending\n" "$running" "$pending"
    printf "tunnels|%s\n" "$tunnels"
    printf "gpu|use option 4\n"
}

refresh_status() {
    local data line key value
    data=$(run_spinner "refreshing Convergence status" collect_status || true)
    while IFS='|' read -r key value; do
        case "$key" in
            front) STATUS_FRONT="$value" ;;
            jobs) STATUS_JOBS="$value" ;;
            tunnels) STATUS_TUNNELS="$value" ;;
            gpu) STATUS_GPU="$value" ;;
        esac
    done <<< "$data"
    STATUS_UPDATED=$(date '+%H:%M:%S' 2>/dev/null || date)
}

