# parse_duration INPUT
# Accepts: 30m, 8h, 3d, 3d 12h, 1d 6h 30m, HH:MM:SS, bare number (hours)
parse_duration() {
    local input
    input=$(printf '%s' "$*" | tr '[:upper:]' '[:lower:]')
    input=$(printf '%s' "$input" | xargs)
    [ -z "$input" ] && return 1

    if [[ "$input" =~ ^[0-9]+:[0-9]+:[0-9]+$ ]]; then
        local h m s
        IFS=':' read -r h m s <<< "$input"
        h=$((10#$h))
        m=$((10#$m))
        s=$((10#$s))
        if [ "$h" -ge 24 ]; then
            local d=$(( h / 24 ))
            local rem_h=$(( h % 24 ))
            printf "%d-%02d:%02d:%02d\n" "$d" "$rem_h" "$m" "$s"
        else
            printf "%02d:%02d:%02d\n" "$h" "$m" "$s"
        fi
        return 0
    fi

    local total_minutes=0
    local matched=false
    if [[ "$input" =~ [dhm] ]]; then
        if [[ "$input" =~ ([0-9]+)d ]]; then
            total_minutes=$(( total_minutes + ${BASH_REMATCH[1]} * 1440 ))
            matched=true
        fi
        if [[ "$input" =~ ([0-9]+)h ]]; then
            total_minutes=$(( total_minutes + ${BASH_REMATCH[1]} * 60 ))
            matched=true
        fi
        if [[ "$input" =~ ([0-9]+)m ]]; then
            total_minutes=$(( total_minutes + ${BASH_REMATCH[1]} ))
            matched=true
        fi
        $matched || return 1
    elif [[ "$input" =~ ^[0-9]+$ ]]; then
        total_minutes=$(( input * 60 ))
    else
        return 1
    fi

    local total_h=$(( total_minutes / 60 ))
    local total_m=$(( total_minutes % 60 ))
    if [ "$total_h" -ge 24 ]; then
        local d=$(( total_h / 24 ))
        local rem_h=$(( total_h % 24 ))
        printf "%d-%02d:%02d:00\n" "$d" "$rem_h" "$total_m"
    else
        printf "%02d:%02d:00\n" "$total_h" "$total_m"
    fi
}

duration_to_minutes() {
    local input
    input=$(printf '%s' "$*" | tr '[:upper:]' '[:lower:]')
    input=$(printf '%s' "$input" | xargs)
    [ -z "$input" ] && echo "0" && return

    if [[ "$input" =~ ^[0-9]+:[0-9]+:[0-9]+$ ]]; then
        local h m s
        IFS=':' read -r h m s <<< "$input"
        h=$((10#$h))
        m=$((10#$m))
        s=$((10#$s))
        echo $(( h * 60 + m ))
        return
    fi

    local total_minutes=0
    if [[ "$input" =~ ([0-9]+)d ]]; then
        total_minutes=$(( total_minutes + ${BASH_REMATCH[1]} * 1440 ))
    fi
    if [[ "$input" =~ ([0-9]+)h ]]; then
        total_minutes=$(( total_minutes + ${BASH_REMATCH[1]} * 60 ))
    fi
    if [[ "$input" =~ ([0-9]+)m ]]; then
        total_minutes=$(( total_minutes + ${BASH_REMATCH[1]} ))
    fi
    if [[ "$input" =~ ^[0-9]+$ ]]; then
        total_minutes=$(( input * 60 ))
    fi
    echo "$total_minutes"
}

spinner_step() {
    local label="$1"
    printf "  ${DIM}%-2s %s...${NC}" ">" "$label"
}

spinner_done() {
    local text="$1"
    printf "\r\033[K  ${GREEN}ok${NC} %s\n" "$text"
}

spinner_warn() {
    local text="$1"
    printf "\r\033[K  ${YELLOW}--${NC} %s\n" "$text"
}

run_spinner() {
    local label="$1"
    shift
    local tmp="${TMPDIR:-/tmp}/lip6-spinner.$$.$RANDOM"
    local frames='|/-\'
    local i=0
    local pid rc

    "$@" > "${tmp}.out" 2> "${tmp}.err" &
    pid=$!
    while kill -0 "$pid" 2>/dev/null; do
        printf "\r\033[K  ${CYAN}%s${NC} %s" "${frames:$((i % 4)):1}" "$label" >&2
        i=$((i + 1))
        sleep 0.12
    done
    wait "$pid"
    rc=$?
    printf "\r\033[K" >&2
    cat "${tmp}.out"
    if [ "$rc" -ne 0 ] && [ -s "${tmp}.err" ]; then
        cat "${tmp}.err" >&2
    fi
    rm -f "${tmp}.out" "${tmp}.err"
    return "$rc"
}

