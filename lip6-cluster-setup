my_jobs() {
    echo ""
    echo -e "${DIM}Loading, please wait...${NC}"

    local raw
    raw=$(ssh conv bash -c "\"squeue -h -u ${CONV_USER} -o '%i|%j|%T|%M|%l|%L|%R'\"" 2>/dev/null)

    if [ -z "$raw" ]; then
        echo -e "${DIM}No running jobs.${NC}"
        echo ""
        return
    fi

    local has_running=false has_pending=false
    local running_lines="" pending_lines=""

    while IFS='|' read -r jid name state elapsed limit left node; do
        [ -z "$jid" ] && continue
        if [ "$state" = "RUNNING" ]; then
            running_lines+="$(printf "  %-8s %-20s %-12s %-12s %-12s %s\n" "$jid" "$name" "$elapsed" "$limit" "$left" "$node")"$'\n'
            has_running=true
        else
            pending_lines+="$(printf "  %-8s %-20s %-12s %s\n" "$jid" "$name" "$limit" "$node")"$'\n'
            has_pending=true
        fi
    done <<< "$raw"

    if $has_running; then
        echo -e "${GREEN}${BOLD}RUNNING${NC}"
        printf "  %-8s %-20s %-12s %-12s %-12s %s\n" "JobID" "Name" "Elapsed" "TimeLimit" "TimeLeft" "Node"
        echo -e "  ${DIM}────────────────────────────────────────────────────────────────────────────────${NC}"
        printf "%s" "$running_lines"
    fi

    if $has_pending; then
        $has_running && echo ""
        echo -e "${YELLOW}${BOLD}PENDING${NC}"
        printf "  %-8s %-20s %-12s %s\n" "JobID" "Name" "TimeLimit" "Reason"
        echo -e "  ${DIM}──────────────────────────────────────────────────────────────${NC}"
        printf "%s" "$pending_lines"
    fi

    echo ""
    echo -e "${DIM}Detailed info on a job:${NC}"
    read -p "Job ID (or Enter to skip): " jobid
    if [ -n "$jobid" ]; then
        if ! is_int "$jobid"; then
            echo -e "${RED}Invalid job ID (must be a number).${NC}"
            return
        fi
        echo ""
        ssh conv "sacct -j '$jobid' --format='JobID,JobName,NodeList,AllocTres%80,Start,End,State' -X 2>/dev/null" 2>/dev/null
    fi
    echo ""
}

cancel_job() {
    echo ""
    echo -e "${DIM}Loading, please wait...${NC}"

    local raw
    raw=$(ssh conv bash -c "\"squeue -h -u ${CONV_USER} -o '%i|%j|%T|%M|%l|%R'\"" 2>/dev/null)

    if [ -z "$raw" ]; then
        echo -e "${DIM}No running jobs to cancel.${NC}"
        return
    fi

    echo -e "${BOLD}Your jobs:${NC}"
    echo ""
    printf "  %-8s %-20s %-10s %-12s %-12s %s\n" "JobID" "Name" "State" "Elapsed" "TimeLimit" "Node"
    echo -e "  ${DIM}────────────────────────────────────────────────────────────────────────────────${NC}"
    while IFS='|' read -r jid name state elapsed limit node; do
        [ -z "$jid" ] && continue
        printf "  %-8s %-20s %-10s %-12s %-12s %s\n" "$jid" "$name" "$state" "$elapsed" "$limit" "$node"
    done <<< "$raw"
    echo ""
    echo -e "Enter a job ID to cancel, or ${BOLD}all${NC} to cancel everything."
    read -p "> " jobid
    if [ "$jobid" = "all" ]; then
        ssh conv "bash -c 'for jid in \$(squeue -h -u ${CONV_USER} -o \"%i\"); do rm -f ~/*-\${jid}.out ~/*-\${jid}.err; done; scancel -u ${CONV_USER}'" 2>/dev/null
        echo -e "${GREEN}All jobs cancelled and log files cleaned up.${NC}"
    elif is_int "$jobid"; then
        ssh conv "scancel '$jobid'; rm -f ~/*-'${jobid}'.out ~/*-'${jobid}'.err" 2>/dev/null
        echo -e "${GREEN}Job $jobid cancelled and log files cleaned up.${NC}"
    elif [ -n "$jobid" ]; then
        echo -e "${RED}Invalid job ID (must be a number, or 'all').${NC}"
    fi
}

