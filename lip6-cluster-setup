launch_session() {
    pick_gpu

    echo ""
    echo -e "${BOLD}How many GPUs?${NC}"
    echo -e "  ${DIM}Press Enter for 1 (max 4 per node for full, 8 for MIG)${NC}"
    read -p "> " num_gpus
    num_gpus="${num_gpus:-1}"
    if ! is_int "$num_gpus"; then
        echo -e "${RED}GPU count must be a number (e.g. 1, 2, 4).${NC}"
        return
    fi

    echo ""
    echo -e "${BOLD}How long do you need?${NC}"
    echo -e "  ${DIM}Press Enter for 8 hours. Examples: 8h, 1d 6h, 08:00:00${NC}"
    read -p "> " wall_input
    wall_input="${wall_input:-8h}"
    wall=$(parse_duration "$wall_input") || {
        echo -e "${RED}Invalid duration. Use 8h, 1d 6h, 30m, or HH:MM:SS.${NC}"
        return
    }

    echo ""
    echo -e "${BOLD}Job name?${NC}"
    echo -e "  ${DIM}Press Enter for 'gpu-session' (letters, digits, hyphens, underscores only)${NC}"
    read -p "> " job_name
    job_name="${job_name:-gpu-session}"
    if ! is_name "$job_name"; then
        echo -e "${RED}Invalid job name. Use only letters, digits, hyphens, underscores.${NC}"
        return
    fi

    echo ""
    echo -e "${BOLD}CPU vendor?${NC}"
    echo -e "  ${GREEN}1${NC})  Intel"
    echo -e "  ${GREEN}2${NC})  AMD"
    echo ""
    read -p "> " cpu_choice
    cpu_choice="${cpu_choice:-1}"
    case $cpu_choice in
        1) CPU_FEATURE="intel" ;;
        2) CPU_FEATURE="amd" ;;
        *) echo -e "${RED}Choose 1 or 2.${NC}"; return ;;
    esac
    if [ "$GPU_TYPE" = "a100_3g.40gb" ] && [ "$CPU_FEATURE" = "amd" ]; then
        echo -e "${RED}AMD is only available on the full A100 node. Choose A100 80GB full or Intel.${NC}"
        return
    fi

    echo ""
    echo -e "${BOLD}RAM size?${NC}"
    echo -e "  ${DIM}Press Enter for Slurm default. Examples: 128G, 512G, 2048000M, 0 for full node memory${NC}"
    read -p "> " MEMORY
    if [ -n "$MEMORY" ] && ! is_mem "$MEMORY"; then
        echo -e "${RED}Invalid RAM size. Examples: 128G, 512G, 2048000M, or 0.${NC}"
        return
    fi

    pick_node_for_gpu_type "$GPU_TYPE" || return

    echo ""
    echo -e "${BOLD}How do you want to work?${NC}"
    echo -e "  ${GREEN}1${NC})  Jupyter Lab (opens in browser)"
    echo -e "  ${GREEN}2${NC})  Terminal only (SSH into compute node)"
    echo -e "  ${GREEN}3${NC})  Both (Jupyter + terminal access)"
    echo -e "  ${GREEN}4${NC})  Submit a custom script"
    echo ""
    read -p "> " mode
    mode="${mode:-1}"
    if ! [[ "$mode" =~ ^[1-4]$ ]]; then
        echo -e "${RED}Choose 1, 2, 3, or 4.${NC}"
        return
    fi

    if [ "$mode" = "4" ]; then
        submit_custom "$num_gpus" "$wall" "$job_name" "$CPU_FEATURE" "$MEMORY" "$NODE_LIST"
        return
    fi

    SLURM_EXTRA=$(slurm_options "$CPU_FEATURE" "$MEMORY" "$NODE_LIST")

    if [ "$mode" = "2" ]; then
        echo ""
        echo -e "${CYAN}Requesting interactive session: ${num_gpus}x ${GPU_TYPE}, ${wall}...${NC}"
        echo -e "${DIM}This is interactive — dies when you disconnect.${NC}"
        echo -e "${DIM}Use option 1 or 3 for persistent Jupyter sessions.${NC}"
        echo ""
        echo -e "${DIM}salloc --job-name='${job_name}' --nodes=1 --gpus-per-node='${GPU_TYPE}:${num_gpus}' --time='${wall}'${SLURM_EXTRA}${NC}"
        ssh -t conv "salloc --job-name='${job_name}' --nodes=1 --gpus-per-node='${GPU_TYPE}:${num_gpus}' --time='${wall}'${SLURM_EXTRA}"
        return
    fi

    echo ""
    echo -e "${CYAN}Submitting Jupyter Lab: ${num_gpus}x ${GPU_TYPE}, ${wall}...${NC}"
    echo -e "${DIM}sbatch --job-name='${job_name}' --nodes=1 --gpus-per-node='${GPU_TYPE}:${num_gpus}' --time='${wall}'${SLURM_EXTRA}${NC}"

    spinner_step "checking Jupyter env"
    jupyter_check=$(ssh conv 'test -x ~/.venvs/conv_jupyter/bin/jupyter && echo ok' 2>/dev/null || true)
    if [ -z "$jupyter_check" ]; then
        spinner_warn "Jupyter missing; installing in ~/.venvs/conv_jupyter"
        ssh conv 'source /etc/profile.d/modules.sh 2>/dev/null; module purge; module load python/anaconda3; python -m venv ~/.venvs/conv_jupyter && ~/.venvs/conv_jupyter/bin/python -m pip install --quiet --upgrade pip jupyterlab' 2>/dev/null
        if [ $? -ne 0 ]; then
            echo -e "${RED}Failed to install Jupyter. Check manually.${NC}"
            return
        fi
    else
        spinner_done "Jupyter env ready"
    fi

    JOBID=$(ssh conv bash -s "$num_gpus" "$GPU_TYPE" "$wall" "$job_name" "$CPU_FEATURE" "$MEMORY" "$NODE_LIST" << 'REMOTE'
NUM_GPUS="$1"
GPU_TYPE="$2"
WALL="$3"
JOB_NAME="$4"
CPU_FEATURE="$5"
MEMORY="$6"
NODE_LIST="$7"
CONSTRAINT_LINE=""
MEMORY_LINE=""
NODE_LINE=""
[ -n "$CPU_FEATURE" ] && CONSTRAINT_LINE="#SBATCH --constraint=${CPU_FEATURE}"
[ -n "$MEMORY" ] && MEMORY_LINE="#SBATCH --mem=${MEMORY}"
[ -n "$NODE_LIST" ] && NODE_LINE="#SBATCH --nodelist=${NODE_LIST}"
cat > ~/._conv_jupyter.sh << JOBSCRIPT
#!/bin/bash
#SBATCH --job-name=${JOB_NAME}
#SBATCH --nodes=1
#SBATCH --gpus-per-node=${GPU_TYPE}:${NUM_GPUS}
#SBATCH --time=${WALL}
${CONSTRAINT_LINE}
${MEMORY_LINE}
${NODE_LINE}
#SBATCH --mail-type=ALL
#SBATCH --mail-user=allaa.boutaleb@lip6.fr
#SBATCH --output=%x-%j.out
#SBATCH --error=%x-%j.err

source /etc/profile.d/modules.sh
module purge
module load python/anaconda3
eval "\$(conda shell.bash hook)"
source ~/.venvs/conv_jupyter/bin/activate

JUPYTER_PORT=\$(shuf -i 10000-60000 -n 1)
jupyter lab --ip=0.0.0.0 --no-browser --port=\${JUPYTER_PORT}
JOBSCRIPT
sbatch ~/._conv_jupyter.sh 2>&1 | grep -oP 'Submitted batch job \K[0-9]+'
REMOTE
    )

    if [ -z "$JOBID" ] || ! is_int "$JOBID"; then
        echo -e "${RED}Failed to submit job.${NC}"
        return
    fi

    echo -e "${GREEN}Job $JOBID submitted.${NC} Waiting for it to start..."
    echo -e "${DIM}(Convergence queue can take minutes to hours depending on load)${NC}"
    sleep 5

    local attempts=0
    while true; do
        STATE=$(ssh conv bash -c "\"squeue -j $JOBID -h -o '%T'\"" 2>/dev/null)
        if [ "$STATE" = "RUNNING" ]; then
            break
        elif [ "$STATE" = "FAILED" ] || [ "$STATE" = "CANCELLED" ] || [ "$STATE" = "TIMEOUT" ]; then
            echo -e "${RED}Job failed (state: $STATE)${NC}"
            echo -e "Check logs: ${DIM}ssh conv 'cat ~/${job_name}-${JOBID}.err'${NC}"
            return
        elif [ -z "$STATE" ]; then
            local sacct_state
            sacct_state=$(ssh conv "sacct -j '$JOBID' --format=State -X --noheader 2>/dev/null | tr -d ' '" 2>/dev/null)
            if [ -n "$sacct_state" ] && [ "$sacct_state" != "PENDING" ] && [ "$sacct_state" != "RUNNING" ]; then
                echo -e "${RED}Job ended (state: ${sacct_state:-unknown})${NC}"
                echo -e "Check logs: ${DIM}ssh conv 'cat ~/${job_name}-${JOBID}.err'${NC}"
                return
            fi
        fi
        attempts=$((attempts + 1))
        if [ $attempts -gt 120 ]; then
            echo -e "${YELLOW}Still queued after 10 min. Job $JOBID is waiting for GPUs.${NC}"
            echo -e "Use option 2 to connect later, or option 4 to cancel."
            return
        fi
        echo -e "  ${DIM}${STATE:-PENDING}... ($((attempts * 5))s)${NC}"
        sleep 5
    done

    connect_to_job "$JOBID" "$mode" "$job_name"
}

