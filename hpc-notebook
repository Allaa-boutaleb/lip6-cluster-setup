collect_status() {
    local output jobs tunnels
    output=$(ssh -n -o BatchMode=yes -o ConnectTimeout=3 hpc "printf 'login|reachable\n'; oarstat -u boutalebm 2>/dev/null" 2>/dev/null || true)
    if ! printf '%s\n' "$output" | grep -q '^login|reachable$'; then
        printf "login|unreachable\n"
        printf "jobs|not available\n"
        printf "tunnels|%s\n" "$(find "$TUNNEL_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')"
        return
    fi

    printf "login|reachable\n"
    jobs=$(printf '%s\n' "$output" | awk '/^[0-9]/{c++} END{print c+0}')
    tunnels=$(find "$TUNNEL_DIR" -type f 2>/dev/null | wc -l | tr -d ' ')
    printf "jobs|%s active\n" "$jobs"
    printf "tunnels|%s\n" "$tunnels"
}

refresh_status() {
    local data line key value
    data=$(run_spinner "refreshing HPC status" collect_status || true)
    while IFS='|' read -r key value; do
        case "$key" in
            login) STATUS_LOGIN="$value" ;;
            jobs) STATUS_JOBS="$value" ;;
            tunnels) STATUS_TUNNELS="$value" ;;
        esac
    done <<< "$data"
    STATUS_UPDATED=$(date '+%H:%M:%S' 2>/dev/null || date)
}

render_status() {
    echo ""
    printf "  ${BOLD}Status${NC} ${DIM}(cached %s, press r to refresh)${NC}\n" "$STATUS_UPDATED"
    printf "  ${GREEN}login${NC}: %s  ${GREEN}jobs${NC}: %s  ${GREEN}tunnels${NC}: %s\n" \
        "$STATUS_LOGIN" "$STATUS_JOBS" "$STATUS_TUNNELS"
}

