    echo ""
    echo -e "${CYAN}Submitting job: ${cores} cores, ${wall}...${NC}"
    echo -e "${DIM}oarsub -l /nodes=1/core=${cores},walltime=${wall} -p \"host like 'big%'\"${NC}"

